# Copy this file to .env and fill in your values
# Do not commit .env to GitHub

# Server (works locally and on a server)
PORT=5000
# HOST=0.0.0.0   # default: accept connections from any interface (local + server)
# HOST=127.0.0.1 # use only for local-only access

# Database (use a real URI on a server, e.g. MongoDB Atlas)
MONGO_URI=mongodb://localhost:27017/lms

JWT_SECRET=your-secret-key-change-in-production
